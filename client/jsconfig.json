{
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "baseUrl": "./",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ]
  },
  "include": ["src/**/*"],  // ✅ `src/` 내부의 모든 파일을 포함하도록 설정
  "exclude": ["node_modules", "dist"]  // ✅ `node_modules`과 `dist` 폴더 제외
}
