# The server-unit ordering in After= below only applies when the server is
# co-located on this host (an "all" install). For agent-only deployments the
# installer strips that token, since no such unit exists on the machine.
[Unit]
Description=TimeWeaver Scheduler Agent
After=network-online.target timeweaver-server.service
Wants=network-online.target

[Service]
Type=simple
User=__TIMEWEAVER_USER__
WorkingDirectory=__TIMEWEAVER_ROOT__/agent
Environment=PYTHONUNBUFFERED=1
ExecStart=__TIMEWEAVER_ROOT__/agent/.venv/bin/python timeweaver.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
